# AU Mosaic environment. Copy to .env and fill in.
# Public site
NEXT_PUBLIC_WHATSAPP=234XXXXXXXXXX
NEXT_PUBLIC_PHONE_DISPLAY="+234 XXX XXX XXXX"

# Neon Postgres (Vercel integration; run `vercel env pull` or paste from the dashboard)
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Back office
AUTH_SECRET=generate-with: openssl rand -hex 32
ADMIN_PASSWORD=changeme

# Piece photographs (Vercel Blob; create a store in the Vercel dashboard)
BLOB_READ_WRITE_TOKEN=from-the-vercel-dashboard

# Canonical URL (localhost in dev, the real domain in Vercel)
NEXT_PUBLIC_URL=http://localhost:3000

# Notifications (Web Push). Generate once: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=from-generate-vapid-keys
VAPID_PRIVATE_KEY=from-generate-vapid-keys

# The morning digest (Vercel Cron). Generate: openssl rand -hex 16
CRON_SECRET=generate-with: openssl rand -hex 16

# The AI reads (insights, chat-to-order). One key, server only, never logged
CLAUDE_API_KEY=from-console-anthropic-com

# The visualizer's surface finder (fal.ai segmentation). Server only, never logged
FAL_KEY=from-fal-ai-dashboard

# The visualizer spend guard (Upstash Redis; create a database at console.upstash.com)
UPSTASH_REDIS_REST_URL=from-the-upstash-console
UPSTASH_REDIS_REST_TOKEN=from-the-upstash-console

# Paid visualizer calls allowed per day, shared across the whole app
VISUALIZER_DAILY_CAP=200
# VISUALIZER_SAM_PROVIDER=sam2  # escape hatch back to the old sync provider

# Optional: override the visualizer's vision model (defaults to the pinned Haiku snapshot)
# CLAUDE_VISUALIZER_MODEL=claude-haiku-4-5-20251001
