{
  "name": "au-mosaic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/copy-ort.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/copy-ort.mjs && node scripts/fetch-sam-model.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "media:backfill": "tsx scripts/media-backfill.ts",
    "media:raw": "tsx scripts/media-raw-import.ts",
    "media:import": "npm run media:backfill && npm run media:raw",
    "demo:seed": "tsx scripts/demo-seed.ts",
    "demo:clear": "tsx scripts/demo-seed.ts --clear",
    "reset:book": "tsx scripts/reset-book.ts",
    "test": "tsc -p tsconfig.tests.json && node --test \".tests-out/tests/*.test.js\""
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.18",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.5.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "onnxruntime-web": "^1.27.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.22.5",
    "typescript": "^5"
  }
}
